# Public canonical URL of the site (used for SEO: canonical, sitemap, OG tags).
# Resolved at runtime, so changing it does NOT require a rebuild. Local dev can
# leave it unset. In production set it to your real domain, e.g.
# https://soarappliancerepair.com  — on Railway it falls back to RAILWAY_PUBLIC_DOMAIN.
SITE_URL=

# URL of the Python Telegram bot's /notify endpoint.
# Local:    http://localhost:8000/notify
# Railway:  http://${{bot.RAILWAY_PRIVATE_DOMAIN}}:8000/notify  (private networking)
BOT_NOTIFY_URL=http://localhost:8000/notify

# Optional shared secret. If set here, it must match NOTIFY_TOKEN in the bot service.
BOT_NOTIFY_TOKEN=

# Optional: Google Search Console verification token (the content="..." value of
# the google-site-verification meta tag). Lets you verify the site for SEO.
GOOGLE_SITE_VERIFICATION=
