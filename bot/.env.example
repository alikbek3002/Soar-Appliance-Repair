# Token from @BotFather on Telegram (required).
TELEGRAM_BOT_TOKEN=

# Optional shared secret. If set, the Next.js site must send the same value
# as BOT_NOTIFY_TOKEN so only your site can trigger broadcasts.
NOTIFY_TOKEN=

# Where to persist subscriber chat IDs (optional; defaults to ./subscribers.json).
# On Railway, mount a volume and point this at it so subscribers survive redeploys:
#   SUBSCRIBERS_FILE=/data/subscribers.json
# SUBSCRIBERS_FILE=subscribers.json
